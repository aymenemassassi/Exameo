# =============================================================================
# Exameo - Local development environment variables
# Copy this file to .env (which is git-ignored) before docker compose up
# =============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=exameo
POSTGRES_PASSWORD=exameo
POSTGRES_DB=exameo

# --- Keycloak ---------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=Admin123!
KC_HOSTNAME=localhost
KC_HTTP_PORT=8081

# --- MinIO ------------------------------------------------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# --- Grafana ----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Mail (dev: MailHog) ----------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025

# --- Services internal ports (host) ----------------------------------------
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8082
EXAM_SERVICE_PORT=8083
GRADING_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
AI_SERVICE_PORT=8086
PROCTORING_SERVICE_PORT=8087
WEB_PORT=3000

# --- AI service (BYOK) ------------------------------------------------------
# Choose ONE of these strategies. If none set, ai-service falls back to a
# deterministic stub that returns canned QCMs (useful for tests/CI).
#
# Strategy 1: Ollama local (default, fully offline, free)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1:8b
#
# Strategy 2: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
#
# Strategy 3: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Frontend (NextAuth) ----------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-please-32chars-min-aaaa
KEYCLOAK_CLIENT_ID=web
KEYCLOAK_CLIENT_SECRET=web-secret
KEYCLOAK_ISSUER=http://localhost:8081/realms/exameo

# --- Observability ----------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
