{
  "title": "Exameo - Overview",
  "uid": "exameo-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["exameo", "platform"],
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {"refresh_intervals": ["10s", "30s", "1m", "5m"]},
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests per second (api-gateway)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"spring-actuator\",service=\"api-gateway\"}[1m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "JVM memory used",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "decbytes"}, "overrides": []},
      "targets": [
        {
          "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Logs by service",
      "type": "logs",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8},
      "options": {"showTime": true, "wrapLogMessage": true},
      "targets": [
        {
          "expr": "{service=~\".+\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
