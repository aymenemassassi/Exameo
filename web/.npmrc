; Configuration npm specifique au projet Exameo (poste pro)
; Override le Nexus interne configure dans ~/.npmrc (qui n'est pas
; accessible sans VPN et pas pertinent pour un repo open-source perso).
;
; Le registry public npmjs est utilise via le proxy d'entreprise
; (HTTP_PROXY / HTTPS_PROXY env vars).
registry=https://registry.npmjs.org/
audit=false
fund=false
save-exact=true
save-prefix=
